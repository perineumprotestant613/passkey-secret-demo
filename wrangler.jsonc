{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "passkey-secret-demo",
  "compatibility_date": "2026-04-01",

  // This worker only serves the built static assets from ./dist.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },

  "observability": {
    "enabled": true
  }
}
